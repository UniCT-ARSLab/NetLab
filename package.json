{
  "name": "netlab-app",
  "version": "0.1.0",
  "description": "Network Lab tool for students",
  "author": "OttavioCas",
  "main": "dist/electron/main.js",
  "scripts": {
    "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "start:frontend": "cd frontend && npx ng serve",
    "start:backend": "tsc -p tsconfig.backend.json --watch",
    "electron": "wait-on http://localhost:4200 && electron .",
    "dev": "concurrently \"npm run start:frontend\" \"npm run start:backend\" \"npm run electron\"",
    "build:frontend": "cd frontend && npx ng build --output-path ../dist/frontend --base-href ./",
    "build:backend": "tsc -p tsconfig.backend.json",
    "build:all": "npm run build:frontend && npm run build:backend",
    "package": "npm install && cd frontend && npm install && cd .. && npm run build:all && electron-builder",
    "package:win": "npm install && cd frontend && npm install && cd .. && npm run build:all && electron-builder --win",
    "package:mac": "npm install && cd frontend && npm install && cd .. && npm run build:all && electron-builder --mac",
    "package:linux": "npm install && cd frontend && npm install && cd .. && npm run build:all && electron-builder --linux"
  },
  "dependencies": {
    "dockerode": "^4.0.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "4.0.4",
    "@types/dockerode": "^3.3.23",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^8.0.0",
    "electron": "^41.7.0",
    "electron-builder": "26.8.1",
    "typescript": "^5.3.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.netlab.app",
    "productName": "NetLab",
    "copyright": "Copyright © 2026 NetLab",
    "icon": "build/icon.png",
    "publish": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "npmRebuild": false,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "NetLab",
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "uninstallDisplayName": "NetLab"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.education"
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Education"
    }
  }
}
